<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
    bootstrap="vendor/codeigniter4/framework/system/Test/bootstrap.php"
    backupGlobals="false"
    beStrictAboutOutputDuringTests="true"
    colors="true"
    columns="max"
    failOnRisky="true"
    failOnWarning="false"
    cacheDirectory="build/.phpunit.cache"
>
    <testsuites>
        <testsuite name="App">
            <directory>./tests/unit</directory>
        </testsuite>
    </testsuites>

    <logging>
        <testdoxHtml outputFile="build/logs/testdox.html"/>
        <testdoxText outputFile="build/logs/testdox.txt"/>
        <junit outputFile="build/logs/logfile.xml"/>
    </logging>

    <source>
        <include>
            <directory suffix=".php">./app</directory>
        </include>
        <exclude>
            <directory suffix=".php">./app/Views</directory>
            <file>./app/Config/Routes.php</file>
        </exclude>
    </source>

    <php>
        <server name="app.baseURL" value="http://example.com/"/>
        <server name="CODEIGNITER_SCREAM_DEPRECATIONS" value="0"/>
        <!-- Directory containing phpunit.xml -->
        <const name="HOMEPATH" value="./"/>
        <!-- Directory containing the Paths config file -->
        <const name="CONFIGPATH" value="./app/Config/"/>
        <!-- Directory containing the front controller (index.php) -->
        <const name="PUBLICPATH" value="./public/"/>
        <!-- Database configuration: use 127.0.0.1 for TCP (Docker CI has no Unix socket) -->
        <env name="database.tests.hostname" value="127.0.0.1"/>
        <env name="database.tests.database" value="ci4_board_test"/>
        <env name="database.tests.username" value="ci4user"/>
        <env name="database.tests.password" value="ci4pass"/>
        <env name="database.tests.DBDriver" value="MySQLi"/>
        <env name="database.tests.DBPrefix" value=""/>
        <env name="database.tests.charset" value="utf8mb4"/>
        <env name="database.tests.DBCollat" value="utf8mb4_unicode_ci"/>
        <!-- Admin DB shares the test DB in CI (admin migrations run under tests group) -->
        <env name="database.admin.hostname" value="127.0.0.1"/>
        <env name="database.admin.database" value="ci4_board_test"/>
        <env name="database.admin.username" value="ci4user"/>
        <env name="database.admin.password" value="ci4pass"/>
        <env name="database.admin.DBDriver" value="MySQLi"/>
        <env name="database.admin.DBPrefix" value=""/>
        <env name="database.admin.charset" value="utf8mb4"/>
        <env name="database.admin.DBCollat" value="utf8mb4_unicode_ci"/>
    </php>
</phpunit>
